# Get this token from @BotFather on Telegram (send /newbot)
BOT_TOKEN=put-your-botfather-token-here

# Your Telegram numeric user ID(s) that receive new leads.
# Comma-separated for multiple admins. Find yours via @userinfobot.
ADMIN_IDS=123456789

# Optional: defaults to a local SQLite file. Leave as-is to start.
# DB_URL=sqlite+aiosqlite:///partners.db
